generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(255)
  logoUrl           String?  @map("logo_url")
  timezone          String?  @default("Asia/Kolkata") @db.VarChar(100)
  currency          String?  @default("INR") @db.VarChar(10)
  fiscalYearStart   Int?     @default(4) @map("fiscal_year_start")
  workWeekStart     String?  @default("Monday") @map("work_week_start") @db.VarChar(10)
  address           String?
  sector            String?  @db.VarChar(100)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz
  users             User[]

  @@map("organization")
}

model Department {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  parentId    Int?         @map("parent_id")
  isActive    Boolean?     @default(true) @map("is_active")
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamptz
  parent      Department?  @relation("DepartmentToDepartment", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentToDepartment")
  employees   Employee[]

  @@map("departments")
}

model Location {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(255)
  address   String?
  isActive  Boolean?   @default(true) @map("is_active")
  employees Employee[]

  @@map("locations")
}

model Shift {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(255)
  startTime  DateTime   @map("start_time") @db.Time
  endTime    DateTime   @map("end_time") @db.Time
  workDays   String?    @default("Mon,Tue,Wed,Thu,Fri") @map("work_days") @db.VarChar(20)
  isDefault  Boolean?   @default(false) @map("is_default")
  employees  Employee[]

  @@map("shifts")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  role           Role
  refreshToken   String?   @map("refresh_token")
  isActive       Boolean?  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz
  failedAttempts Int?      @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz
  organizationId Int?      @map("organization_id")
  createdByAdminId Int?    @map("created_by_admin_id")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz
  
  employee       Employee?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  createdMembers   User[]    @relation("UserToUser")
  createdByAdmin   User?     @relation("UserToUser", fields: [createdByAdminId], references: [id])
  
  tasksAssigned    Task[]    @relation("AssignedTo")
  tasksCreated     Task[]    @relation("AssignedBy")

  @@map("users")
}

enum Role {
  admin
  manager
  employee
}

model Employee {
  id                      Int       @id @default(autoincrement())
  userId                  Int?      @unique @map("user_id")
  employeeCode            String    @unique @map("employee_code") @db.VarChar(50)
  firstName               String    @map("first_name") @db.VarChar(100)
  lastName                String    @map("last_name") @db.VarChar(100)
  profilePhotoUrl         String?   @map("profile_photo_url")
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  gender                  String?   @db.VarChar(20)
  bloodGroup              String?   @map("blood_group") @db.VarChar(10)
  workEmail               String?   @map("work_email") @db.VarChar(255)
  workPhone               String?   @map("work_phone") @db.VarChar(25)
  personalEmail           String?   @map("personal_email") @db.VarChar(255)
  personalPhone           String?   @map("personal_phone") @db.VarChar(25)
  emergencyName           String?   @map("emergency_name") @db.VarChar(255)
  emergencyPhone          String?   @map("emergency_phone") @db.VarChar(25)
  departmentId            Int?      @map("department_id")
  locationId              Int?      @map("location_id")
  shiftId                 Int?      @map("shift_id")
  managerId               Int?      @map("manager_id")
  designation             String?   @db.VarChar(255)
  employmentType          String?   @default("full_time") @map("employment_type") @db.VarChar(50)
  employmentStatus        String?   @default("active") @map("employment_status") @db.VarChar(30)
  dateHired               DateTime  @map("date_hired") @db.Date
  contractedHoursPerWeek  Decimal?  @default(40.00) @map("contracted_hours_per_week") @db.Decimal(5, 2)
  fte                     Decimal?  @default(1.00) @map("fte") @db.Decimal(3, 2)
  bankName                String?   @map("bank_name") @db.VarChar(100)
  bankAccountEnc          String?   @map("bank_account_enc")
  bankIfsc                String?   @map("bank_ifsc") @db.VarChar(20)
  addressLine1            String?   @map("address_line1")
  city                    String?   @db.VarChar(100)
  state                   String?   @db.VarChar(100)
  postalCode              String?   @map("postal_code") @db.VarChar(20)
  country                 String?   @default("India") @db.VarChar(100)
  createdAt               DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime? @default(now()) @map("updated_at") @db.Timestamptz

  user            User?           @relation(fields: [userId], references: [id])
  department      Department?     @relation(fields: [departmentId], references: [id])
  location        Location?       @relation(fields: [locationId], references: [id])
  shift           Shift?          @relation(fields: [shiftId], references: [id])
  manager         Employee?       @relation("EmployeeToEmployee", fields: [managerId], references: [id])
  subordinates    Employee[]      @relation("EmployeeToEmployee")
  attendanceSegments AttendanceSegment[]

  @@map("employees")
}

model AttendanceSegment {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  date       DateTime  @db.Date
  checkIn    DateTime  @map("check_in") @db.Timestamptz
  checkOut   DateTime? @map("check_out") @db.Timestamptz
  source     String?   @default("web") @db.VarChar(20)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
  @@index([checkIn])
  @@map("attendance_segments")
}

model Task {
  id           Int       @id @default(autoincrement())
  subject      String    @db.VarChar(255)
  taskName     String    @map("task_name") @db.VarChar(255)
  description  String?
  assignedToId Int       @map("assigned_to_id")
  assignedById Int       @map("assigned_by_id")
  dateAssigned DateTime  @default(now()) @map("date_assigned") @db.Date
  dueDate      DateTime  @map("due_date") @db.Date
  status       String    @default("Pending") @db.VarChar(20) // Pending, In Progress, Completed
  priority     String    @default("Medium") @db.VarChar(20) // Low, Medium, High
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz

  assignedTo   User      @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy   User      @relation("AssignedBy", fields: [assignedById], references: [id])

  @@map("tasks")
}
