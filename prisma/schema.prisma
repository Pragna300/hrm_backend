generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Subscription plan offered to companies that sign up to the platform.
model Plan {
  id            Int            @id @default(autoincrement())
  name          String         @unique @db.VarChar(100)
  slug          String         @unique @db.VarChar(100)
  description   String?
  monthlyPrice  Decimal        @default(0) @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice   Decimal        @default(0) @map("yearly_price") @db.Decimal(10, 2)
  currency      String         @default("USD") @db.VarChar(10)
  seatLimit     Int            @default(10) @map("seat_limit")
  features      String?
  isActive      Boolean        @default(true) @map("is_active")
  isDefault     Boolean        @default(false) @map("is_default")
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscriptions Subscription[]

  @@map("plans")
}

/// Active or historical subscription of an organization to a plan.
model Subscription {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  planId         Int          @map("plan_id")
  status         String       @default("trialing") @db.VarChar(30)
  billingCycle   String       @default("monthly") @map("billing_cycle") @db.VarChar(20)
  unitAmount     Decimal      @map("unit_amount") @db.Decimal(10, 2)
  currency       String       @default("USD") @db.VarChar(10)
  startedAt      DateTime     @default(now()) @map("started_at") @db.Timestamptz(6)
  currentStart   DateTime     @map("current_start") @db.Timestamptz(6)
  currentEnd     DateTime     @map("current_end") @db.Timestamptz(6)
  cancelledAt    DateTime?    @map("cancelled_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  invoices       Invoice[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@map("subscriptions")
}

/// Issued invoice (revenue record) for a subscription period.
model Invoice {
  id             Int          @id @default(autoincrement())
  subscriptionId Int          @map("subscription_id")
  organizationId Int          @map("organization_id")
  number         String       @unique @db.VarChar(40)
  amount         Decimal      @db.Decimal(10, 2)
  currency       String       @default("USD") @db.VarChar(10)
  status         String       @default("issued") @db.VarChar(20)
  periodStart    DateTime     @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime     @map("period_end") @db.Timestamptz(6)
  issuedAt       DateTime     @default(now()) @map("issued_at") @db.Timestamptz(6)
  paidAt         DateTime?    @map("paid_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("invoices")
}

model Organization {
  id                Int                @id @default(autoincrement())
  name              String             @db.VarChar(255)
  slug              String             @unique @db.VarChar(120)
  logoUrl           String?            @map("logo_url")
  timezone          String?            @default("Asia/Kolkata") @db.VarChar(100)
  currency          String?            @default("INR") @db.VarChar(10)
  fiscalYearStart   Int?               @default(4) @map("fiscal_year_start")
  workWeekStart     String?            @default("Monday") @map("work_week_start") @db.VarChar(10)
  address           String?
  sector            String?            @db.VarChar(100)
  contactEmail      String?            @map("contact_email") @db.VarChar(255)
  contactPhone      String?            @map("contact_phone") @db.VarChar(50)
  status            String             @default("active") @db.VarChar(30)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  trialEndsAt       DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  announcements     Announcement[]
  contactInquiries  ContactInquiry[]
  departments       Department[]
  employeeDocuments EmployeeDocument[]
  employeeTasks     EmployeeTask[]
  employees         Employee[]
  holidays          Holiday[]
  invoices          Invoice[]
  leaveRequests     LeaveRequest[]
  leaveTypes        LeaveType[]
  locations         Location[]
  newsPosts         NewsPost[]
  notifications     Notification[]
  payrollRuns       PayrollRun[]
  shifts            Shift[]
  subscriptions     Subscription[]
  users             User[]

  @@map("organization")
}

model User {
  id                       Int                @id @default(autoincrement())
  email                    String             @unique @db.VarChar(255)
  passwordHash             String             @map("password_hash") @db.VarChar(255)
  role                     Role
  refreshToken             String?            @map("refresh_token")
  isActive                 Boolean            @default(true) @map("is_active")
  lastLoginAt              DateTime?          @map("last_login_at") @db.Timestamptz(6)
  failedAttempts           Int                @default(0) @map("failed_attempts")
  lockedUntil              DateTime?          @map("locked_until") @db.Timestamptz(6)
  resetToken               String?            @map("reset_token") @db.VarChar(255)
  resetTokenExpires        DateTime?          @map("reset_token_expires") @db.Timestamptz(6)
  organizationId           Int?               @map("organization_id")
  createdByAdminId         Int?               @map("created_by_admin_id")
  createdAt                DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  contactInquiriesAssigned ContactInquiry[]
  createdDepartments       Department[]       @relation("CreatedDepartments")
  documentsUploaded        EmployeeDocument[]
  employee                 Employee?
  newsPosts                NewsPost[]
  tasksCreated             Task[]             @relation("AssignedBy")
  tasksAssigned            Task[]             @relation("AssignedTo")
  createdByAdmin           User?              @relation("UserToUser", fields: [createdByAdminId], references: [id])
  createdMembers           User[]             @relation("UserToUser")
  organization             Organization?      @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model Employee {
  id                     Int                  @id @default(autoincrement())
  userId                 Int?                 @unique @map("user_id")
  organizationId         Int                  @map("organization_id")
  employeeCode           String               @map("employee_code") @db.VarChar(50)
  firstName              String               @map("first_name") @db.VarChar(100)
  lastName               String               @map("last_name") @db.VarChar(100)
  profilePhotoUrl        String?              @map("profile_photo_url")
  dateOfBirth            DateTime?            @map("date_of_birth") @db.Date
  gender                 String?              @db.VarChar(20)
  bloodGroup             String?              @map("blood_group") @db.VarChar(10)
  workEmail              String?              @map("work_email") @db.VarChar(255)
  workPhone              String?              @map("work_phone") @db.VarChar(25)
  personalEmail          String?              @map("personal_email") @db.VarChar(255)
  personalPhone          String?              @map("personal_phone") @db.VarChar(25)
  emergencyName          String?              @map("emergency_name") @db.VarChar(255)
  emergencyPhone         String?              @map("emergency_phone") @db.VarChar(25)
  locationId             Int?                 @map("location_id")
  shiftId                Int?                 @map("shift_id")
  designation            String?              @db.VarChar(255)
  employmentType         String?              @default("full_time") @map("employment_type") @db.VarChar(50)
  employmentStatus       String?              @default("active") @map("employment_status") @db.VarChar(30)
  dateHired              DateTime             @map("date_hired") @db.Date
  contractedHoursPerWeek Decimal?             @default(40.00) @map("contracted_hours_per_week") @db.Decimal(5, 2)
  fte                    Decimal?             @default(1.00) @map("fte") @db.Decimal(3, 2)
  monthlyCtc             Decimal?             @default(0) @map("monthly_ctc") @db.Decimal(12, 2)
  bankName               String?              @map("bank_name") @db.VarChar(100)
  bankAccountEnc         String?              @map("bank_account_enc")
  bankIfsc               String?              @map("bank_ifsc") @db.VarChar(20)
  addressLine1           String?              @map("address_line1")
  city                   String?              @db.VarChar(100)
  state                  String?              @db.VarChar(100)
  postalCode             String?              @map("postal_code") @db.VarChar(20)
  country                String?              @default("India") @db.VarChar(100)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  role                   String?              @db.VarChar(100)
  promotionDate          DateTime?            @map("promotion_date") @db.Date
  previousRole           String?              @map("previous_role") @db.VarChar(100)
  roleHistory            Json?                @map("role_history")
  managerId              Int?                 @map("manager_id")
  departments            EmployeeDepartment[]
  attendanceSegments     AttendanceSegment[]
  documents              EmployeeDocument[]
  addedTasks             EmployeeTask[]       @relation("TaskAddedBy")
  assignedTasks          EmployeeTask[]       @relation("TaskAssignee")
  relatedTasks           EmployeeTask[]       @relation("TaskRelatedTo")
  location               Location?            @relation(fields: [locationId], references: [id])
  manager                Employee?            @relation("EmployeeToEmployee", fields: [managerId], references: [id])
  subordinates           Employee[]           @relation("EmployeeToEmployee")
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift                  Shift?               @relation(fields: [shiftId], references: [id])
  user                   User?                @relation(fields: [userId], references: [id])
  leaveBalances          LeaveBalance[]
  approvedLeaves         LeaveRequest[]       @relation("LeaveApprover")
  leaveRequests          LeaveRequest[]       @relation("LeaveRequester")
  payrollItems           PayrollItem[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([managerId])
  @@map("employees")
}

model Department {
  id             Int                  @id @default(autoincrement())
  organizationId Int                  @map("organization_id")
  name           String               @db.VarChar(255)
  createdById    Int?                 @map("created_by_id")
  parentId       Int?                 @map("parent_id")
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  employees      EmployeeDepartment[]
  manager        User?                @relation("CreatedDepartments", fields: [createdById], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Department?          @relation("DepartmentToDepartment", fields: [parentId], references: [id])
  children       Department[]         @relation("DepartmentToDepartment")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("departments")
}

model EmployeeDepartment {
  employeeId   Int
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([employeeId, departmentId])
  @@index([departmentId])
}

model Location {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  name           String       @db.VarChar(255)
  address        String?
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("locations")
}

model Shift {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  name           String       @db.VarChar(255)
  startTime      DateTime     @map("start_time") @db.Time(6)
  endTime        DateTime     @map("end_time") @db.Time(6)
  workDays       String?      @default("Mon,Tue,Wed,Thu,Fri") @map("work_days") @db.VarChar(20)
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("shifts")
}

model AttendanceSegment {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  date       DateTime  @db.Date
  checkIn    DateTime  @map("check_in") @db.Timestamptz(6)
  checkOut   DateTime? @map("check_out") @db.Timestamptz(6)
  source     String?   @default("web") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([date])
  @@index([checkIn])
  @@map("attendance_segments")
}

model LeaveType {
  id             Int            @id @default(autoincrement())
  organizationId Int            @map("organization_id")
  name           String         @db.VarChar(100)
  code           String         @db.VarChar(20)
  yearlyQuota    Decimal        @default(12) @map("yearly_quota") @db.Decimal(5, 2)
  isPaid         Boolean        @default(true) @map("is_paid")
  colorHex       String?        @default("#3174ad") @map("color_hex") @db.VarChar(10)
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  balances       LeaveBalance[]
  requests       LeaveRequest[]
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("leave_types")
}

model LeaveBalance {
  id          Int       @id @default(autoincrement())
  employeeId  Int       @map("employee_id")
  leaveTypeId Int       @map("leave_type_id")
  year        Int
  allocated   Decimal   @default(0) @db.Decimal(5, 2)
  used        Decimal   @default(0) @db.Decimal(5, 2)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  employeeId     Int          @map("employee_id")
  leaveTypeId    Int          @map("leave_type_id")
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime     @map("end_date") @db.Date
  totalDays      Decimal      @map("total_days") @db.Decimal(5, 2)
  reason         String?
  status         String       @default("pending") @db.VarChar(20)
  approverId     Int?         @map("approver_id")
  approverNote   String?      @map("approver_note")
  decidedAt      DateTime?    @map("decided_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  approver       Employee?    @relation("LeaveApprover", fields: [approverId], references: [id])
  employee       Employee     @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      LeaveType    @relation(fields: [leaveTypeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

model Holiday {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  name           String       @db.VarChar(255)
  date           DateTime     @db.Date
  isOptional     Boolean      @default(false) @map("is_optional")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, name])
  @@index([organizationId])
  @@map("holidays")
}

model PayrollRun {
  id             Int           @id @default(autoincrement())
  organizationId Int           @map("organization_id")
  periodStart    DateTime      @map("period_start") @db.Date
  periodEnd      DateTime      @map("period_end") @db.Date
  status         String        @default("draft") @db.VarChar(20)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(14, 2)
  finalizedAt    DateTime?     @map("finalized_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  items          PayrollItem[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("payroll_runs")
}

model PayrollItem {
  id           Int        @id @default(autoincrement())
  payrollRunId Int        @map("payroll_run_id")
  employeeId   Int        @map("employee_id")
  baseSalary   Decimal    @default(0) @map("base_salary") @db.Decimal(12, 2)
  allowances   Decimal    @default(0) @db.Decimal(12, 2)
  deductions   Decimal    @default(0) @db.Decimal(12, 2)
  netPay       Decimal    @default(0) @map("net_pay") @db.Decimal(12, 2)
  notes        String?
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@map("payroll_items")
}

model Announcement {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  title          String       @db.VarChar(255)
  body           String
  postedById     Int?         @map("posted_by_id")
  isPinned       Boolean      @default(false) @map("is_pinned")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("announcements")
}

model Notification {
  id             Int           @id @default(autoincrement())
  organizationId Int?          @map("organization_id")
  userId         Int           @map("user_id")
  type           String        @db.VarChar(50)
  title          String        @db.VarChar(255)
  body           String?
  link           String?       @db.VarChar(255)
  readAt         DateTime?     @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("notifications")
}

model NewsPost {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  authorUserId   Int          @map("author_user_id")
  title          String       @db.VarChar(500)
  body           String
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  author         User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@map("news_posts")
}

model EmployeeDocument {
  id                 Int          @id @default(autoincrement())
  organizationId     Int          @map("organization_id")
  employeeId         Int?         @map("employee_id")
  title              String       @db.VarChar(255)
  description        String?
  fileUrl            String       @map("file_url") @db.VarChar(2000)
  fileType           String?      @map("file_type") @db.VarChar(50)
  fileSize           Int?         @map("file_size")
  category           String?      @db.VarChar(100)
  uploadedByUserId   Int?         @map("uploaded_by_user_id")
  isOrganizationWide Boolean      @default(true) @map("is_organization_wide")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  employee           Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy         User?        @relation(fields: [uploadedByUserId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("employee_documents")
}

model EmployeeTask {
  id                  Int          @id @default(autoincrement())
  organizationId      Int          @map("organization_id")
  assigneeEmployeeId  Int          @map("assignee_employee_id")
  title               String       @db.VarChar(500)
  description         String?
  category            String       @default("Custom Task") @db.VarChar(120)
  dueDate             DateTime     @map("due_date") @db.Date
  status              String       @default("open") @db.VarChar(20)
  addedByEmployeeId   Int?         @map("added_by_employee_id")
  relatedToEmployeeId Int?         @map("related_to_employee_id")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  addedBy             Employee?    @relation("TaskAddedBy", fields: [addedByEmployeeId], references: [id])
  assignee            Employee     @relation("TaskAssignee", fields: [assigneeEmployeeId], references: [id], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  relatedTo           Employee?    @relation("TaskRelatedTo", fields: [relatedToEmployeeId], references: [id])

  @@index([organizationId])
  @@index([assigneeEmployeeId])
  @@index([dueDate])
  @@map("employee_tasks")
}

model Task {
  id           Int       @id @default(autoincrement())
  subject      String    @db.VarChar(255)
  taskName     String    @map("task_name") @db.VarChar(255)
  description  String?
  assignedToId Int       @map("assigned_to_id")
  assignedById Int       @map("assigned_by_id")
  dateAssigned DateTime  @default(now()) @map("date_assigned") @db.Date
  dueDate      DateTime  @map("due_date") @db.Date
  status       String    @default("Pending") @db.VarChar(20)
  priority     String    @default("Medium") @db.VarChar(20)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  assignedBy   User      @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedTo   User      @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@map("tasks")
}

model ContactInquiry {
  id               Int             @id @default(autoincrement())
  organizationId   Int?            @map("organization_id")
  name             String          @db.VarChar(255)
  email            String          @db.VarChar(255)
  organizationName String?         @map("organization_name") @db.VarChar(255)
  inquiryType      InquiryType     @map("inquiry_type")
  subject          String?         @db.VarChar(500)
  message          String
  status           InquiryStatus   @default(PENDING)
  priority         InquiryPriority @default(MEDIUM)
  adminNotes       String?         @map("admin_notes")
  assignedAdminId  Int?            @map("assigned_admin_id")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedAdmin    User?           @relation(fields: [assignedAdminId], references: [id])
  organization     Organization?   @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([inquiryType])
  @@index([createdAt])
  @@map("contact_inquiries")
}

enum Role {
  super_admin
  manager
  hr
  team_lead
  employee
}

enum InquiryType {
  GENERAL
  DEMO_REQUEST
  TECHNICAL_SUPPORT
  EMPLOYEE_ISSUE
  PAYROLL_ISSUE
  ATTENDANCE_ISSUE
  FEATURE_REQUEST
  BUG_REPORT
  PARTNERSHIP
}

enum InquiryStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InquiryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
